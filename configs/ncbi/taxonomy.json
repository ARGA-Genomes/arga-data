{
    "downloading": {
        "retrieveType": "url",
        "tasks": [
            {
                "url": "https://ftp.ncbi.nlm.nih.gov/pub/taxonomy/taxdmp.zip",
                "name": "taxdump.zip"
            }
        ]
    },
    "processing": [
        {
            "path": "./taxonomy.py",
            "function": "parse",
            "inputs": [
                "{D^_}"
            ]
        },
        {
            "path": "./taxonomy.py",
            "function": "getSpecies",
            "inputs": [
                "{P^}"
            ]
        }
    ],
    "conversion": {
        "mapFileName": "ncbi_taxonomy.ttl",
        "input": "{P^}",
        "chunkSize": 65536
    },
    "updating": {
        "type": "weekly",
        "day": "sunday",
        "interval": 2
    }
}