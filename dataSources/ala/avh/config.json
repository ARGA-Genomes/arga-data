{
    "datasetID": "0007001",
    "retrieveType": "script",
    "downloading": {
        "path": ".llib/sharedProcessing.py",
        "function": "collectBiocache",
        "args": [
            {
                "q": "*:*",
                "disableAllQualityFilters": true,
                "qualityProfile": "AVH",
                "fq": [
                    "type_status:*",
                    "country:\"Australia\""
                ],
                "qc": "data_hub_uid:dh9"
            },
            "{OUT-PATH}"
        ],
        "output": "avh.zip"
    },
    "processing": {
        "linear": [
            {
                "path": ".lib/zipping.py",
                "function": "extract",
                "args": [
                    "{IN-PATH}",
                    "{OUT-DIR}"
                ],
                "output": "avh"
            },
            {
                "path": ".llib/sharedProcessing.py",
                "function": "cleanup",
                "args": [
                    "{IN-PATH}",
                    "{OUT-PATH}"
                ],
                "output": "avh.csv"
            }
        ]
    },
    "conversion": {
        "mapID": 404635334
    },
    "update": {
        "type": "weekly",
        "day": "sunday",
        "time": 9,
        "repeat": 2
    }
}
